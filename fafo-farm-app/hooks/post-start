#!/usr/bin/env bash
# post-start hook: add HiddenServicePort 5000 to Tor config for iOS direct access
#
# Umbrel's tor container (getumbrel/tor) generates /tmp/torrc from HS_DIR and
# HS_PORTS env vars at startup. This hook appends a second HiddenServicePort
# mapping so iOS can reach Flask directly on port 5000 via the .onion address.
#
# Container naming on Umbrel:
#   Tor:    fafo-farm-app-tor_server-1
#   Server: fafo-farm-app_server_1  (network aliases: server, fafo-farm-app_server_1)

TOR_CONTAINER="fafo-farm-app-tor_server-1"
SERVER_HOST="fafo-farm-app_server_1"
VIRTUAL_PORT="5000"
SERVER_PORT="5000"
TORRC="/tmp/torrc"
LOG="[fafo-farm-app post-start]"

echo "${LOG} Waiting for Tor container to initialise..."
sleep 6

# Bail silently if the tor container is not running
is_running=$(docker inspect --format '{{.State.Running}}' "${TOR_CONTAINER}" 2>/dev/null) || {
    echo "${LOG} Tor container not found — skipping HiddenServicePort injection"
    exit 0
}

if [ "${is_running}" != "true" ]; then
    echo "${LOG} Tor container exists but is not running — skipping"
    exit 0
fi

# Idempotent: only add the mapping if it isn't already present
if docker exec "${TOR_CONTAINER}" grep -q "HiddenServicePort ${VIRTUAL_PORT}" "${TORRC}" 2>/dev/null; then
    echo "${LOG} HiddenServicePort ${VIRTUAL_PORT} already in torrc — nothing to do"
    exit 0
fi

echo "${LOG} Appending: HiddenServicePort ${VIRTUAL_PORT} ${SERVER_HOST}:${SERVER_PORT}"
docker exec "${TOR_CONTAINER}" sh -c \
    "echo 'HiddenServicePort ${VIRTUAL_PORT} ${SERVER_HOST}:${SERVER_PORT}' >> ${TORRC}" || {
    echo "${LOG} Failed to write to torrc — skipping reload"
    exit 0
}

echo "${LOG} Sending SIGHUP to Tor (PID 1) to reload config..."
docker kill --signal HUP "${TOR_CONTAINER}" || {
    echo "${LOG} Failed to send HUP — Tor may not have reloaded"
    exit 0
}

echo "${LOG} Done. iOS .onion port ${VIRTUAL_PORT} -> ${SERVER_HOST}:${SERVER_PORT}"
